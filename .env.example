# ─────────────────────────────────────────────────────────────
# Larnix — example environment file
# Copy to `.env` and fill in your own values. NEVER commit real keys.
# Every paid-API lesson ships a free local fallback (Ollama) or free tier.
# ─────────────────────────────────────────────────────────────

# Paid LLM APIs (optional — lessons never require these)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Free local fallback (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
